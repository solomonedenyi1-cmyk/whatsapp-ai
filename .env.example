# Mistral API Configuration
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL_NAME=mistral-medium-latest
MISTRAL_CACHE_ENABLED=true

# Mistral Agent Configuration (NEW)
MISTRAL_AGENT_NAME=whatsapp-ai-agent
MISTRAL_AGENT_DESCRIPTION=WhatsApp AI Assistant Agent
MISTRAL_USE_AGENT=true

# Yue-F API Configuration (kept for backward compatibility)
YUE_F_API_URL=https://llm.com
YUE_F_MODEL_NAME=ollama
API_TIMEOUT=30000

# Bot Configuration
BOT_NAME=WhatsApp AI Bot
MAX_CONTEXT_MESSAGES=20
MESSAGE_SPLIT_LENGTH=1500

# Development
NODE_ENV=development
DEBUG=true

# Admin Configuration
ADMIN_WHATSAPP_NUMBER=551234567890@c.us
