# Mistral Agents Configuration
MISTRAL_API_KEY=your_mistral_api_key
MISTRAL_AGENT_ID=ag_your_agent_id

# Mistral Conversations API (beta)
# If true, the bot will keep a server-side conversation history associated with a conversation_id.
MISTRAL_USE_CONVERSATIONS=true
# If false, the conversation will not be stored on Mistral servers (still works, but without server-side persistence).
MISTRAL_CONVERSATION_STORE=true
# Optional. Defaults to server. Allowed values: server, client
MISTRAL_CONVERSATION_HANDOFF_EXECUTION=server

# Audio transcription (WhatsApp voice notes)
# If true, the bot will try to transcribe WhatsApp voice messages (ptt/audio) before sending them to the AI.
MISTRAL_AUDIO_TRANSCRIPTION_ENABLED=true
# Model used by /v1/audio/transcriptions
MISTRAL_AUDIO_TRANSCRIPTION_MODEL=voxtral-mini-latest
# Optional. If empty, language is auto-detected.
# Examples: pt, en, es, fr, de, it
MISTRAL_AUDIO_TRANSCRIPTION_LANGUAGE=

# Text-to-Speech (TTS)
# If true, the bot will reply with a voice note ONLY when the user sent a voice message.
TTS_ENABLED=false
# TTS provider
TTS_PROVIDER=google
# Recommended for WhatsApp voice notes
TTS_MIME_TYPE=audio/ogg; codecs=opus
# Safety limit to avoid generating very long audios
TTS_MAX_CHARS=900

# Google Cloud Text-to-Speech
# Credentials are loaded via Application Default Credentials.
# In Docker, mount the service account JSON and set GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_TTS_LANGUAGE_CODE=pt-BR
# Choose a female voice. Example: pt-BR-Standard-A (female)
GOOGLE_TTS_VOICE_NAME=pt-BR-Standard-A
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0.0

# Bot Configuration
BOT_NAME=WhatsApp AI Bot
MAX_CONTEXT_MESSAGES=20
MESSAGE_SPLIT_LENGTH=1500

# WhatsApp / Puppeteer
WHATSAPP_SESSION_PATH=./session
PUPPETEER_HEADLESS=true
# Optional. Useful in servers where chromium path is custom.
PUPPETEER_EXECUTABLE_PATH=

# Development
NODE_ENV=development
DEBUG=true

# Admin Configuration
ADMIN_WHATSAPP_NUMBER=551234567890@c.us

# Cal.com
CAL_API_KEY=
CAL_EVENT_TYPE_ID=
# Optional. Defaults to https://api.cal.com
CAL_API_URL=
# Optional. Defaults to 2024-08-13
CAL_API_VERSION=
# Optional. Defaults to America/Sao_Paulo
CAL_DEFAULT_TIME_ZONE=

# Resend
RESEND_API_KEY=
RESEND_FROM_NAME=
RESEND_FROM_EMAIL=

# REMEMBER TO SET THIS IN PRODUCTION
