# WhatsApp AI Bot - Environment Configuration
# Copy this file to .env and configure your settings

# =============================================================================
# ADMIN CONFIGURATION
# =============================================================================
# Your WhatsApp number for admin access (format: 5511987654321@c.us)
ADMIN_WHATSAPP_NUMBER=5511987654321@c.us

# =============================================================================
# AI CONFIGURATION
# =============================================================================
# AI API Configuration - Choose your provider
AI_PROVIDER=openai  # Options: openai, anthropic, ollama, custom

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Configuration  
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Ollama Configuration (for local/custom AI)
OLLAMA_API_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b

# Custom AI API Configuration
CUSTOM_AI_API_URL=https://api.example-ai.com/v1
CUSTOM_AI_MODEL=AI
CUSTOM_AI_API_KEY=your_custom_api_key_here

# =============================================================================
# BOT CONFIGURATION
# =============================================================================
# Bot behavior settings
BOT_NAME=WhatsApp AI Assistant
MAX_CONTEXT_MESSAGES=20
MESSAGE_SPLIT_LENGTH=1500
API_TIMEOUT=60
RESPONSE_DELAY=1

# =============================================================================
# SYSTEM CONFIGURATION
# =============================================================================
# Environment and debugging
NODE_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# Database configuration
DATABASE_TYPE=sqlite  # Options: sqlite, json
DATABASE_PATH=data/whatsapp_ai.db

# Session and data paths
SESSION_PATH=.wwebjs_auth
DATA_PATH=data
LOGS_PATH=logs

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================
# Performance optimization settings
ENABLE_CACHING=true
CACHE_TTL=3600
MAX_CONCURRENT_MESSAGES=5
ENABLE_QUEUE_PROCESSING=true

# Timeout settings
AI_TIMEOUT_WARNING=60
AI_TIMEOUT_MAX=120

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Security settings
ENABLE_RATE_LIMITING=true
MAX_MESSAGES_PER_MINUTE=10
ENABLE_ADMIN_COMMANDS=true

# =============================================================================
# CHROME/SELENIUM CONFIGURATION
# =============================================================================
# Chrome browser settings for WhatsApp Web
CHROME_EXECUTABLE_PATH=auto  # auto, or path to chrome executable
CHROME_USER_DATA_DIR=.chrome_user_data
CHROME_HEADLESS=true
CHROME_NO_SANDBOX=true
CHROME_DISABLE_GPU=true
