# Ignore files that shouldn't be copied to Docker image

# Configuration files (will be mounted as volumes)
config.json
.env

# Development files
.git/
.gitignore
*.md
docs/
tests/

# Python cache and build files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Data and session files (will be mounted as volumes)
data/
logs/
.chrome_user_data/
.wwebjs_auth/
.wwebjs_cache/

# Docker files
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD files
.github/
.gitlab-ci.yml

# Local development files
*.local
.env.local
.env.development
.env.test
.env.production

# Temporary files
tmp/
temp/
*.tmp
*.log
