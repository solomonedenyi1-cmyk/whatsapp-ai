{
  "name": "whatsapp-ai-bot",
  "version": "1.0.0",
  "description": "WhatsApp Bot integrated with Mistral Agents API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node --test"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "ai",
    "mistral",
    "agents"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@mistralai/mistralai": "^1.11.0",
    "dotenv": "^16.4.5",
    "qrcode-terminal": "^0.12.0",
    "sqlite3": "^5.1.7",
    "whatsapp-web.js": "^1.25.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "nodemonConfig": {
    "watch": [
      "src",
      "config.json"
    ],
    "ext": "js,json",
    "ignore": [
      "**/.wwebjs_auth/**",
      "**/.wwebjs_cache/**",
      "**/node_modules/**"
    ]
  },
  "overrides": {
    "tar": "7.5.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}